@model Clinc.ViewModels.DashboardVM

@{
    ViewData["Title"] = "لوحة التحكم";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    /* =================================================== */
    /* تنسيق قسم الترحيب والـ Hero Section */
    /* =================================================== */
    .hero-section {
        background: linear-gradient(135deg, #1E3A8A 0%, #3B82F6 100%);
        color: white;
        padding: 2.5rem;
        border-radius: 16px;
        box-shadow: 0 10px 25px rgba(59, 130, 246, 0.15);
    }

        .hero-section h1 {
            font-weight: 700;
            font-size: 2rem;
        }

        .hero-section p {
            opacity: 0.9;
            font-size: 1rem;
            margin-bottom: 0;
        }

    /* =================================================== */
    /* كروت الإحصائيات العامة */
    /* =================================================== */
    .stat-card {
        background: #ffffff;
        border: 1px solid #F1F5F9;
        border-radius: 16px;
        padding: 1.5rem;
        transition: all 0.25s ease;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02);
        position: relative;
        overflow: hidden;
    }

        .stat-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
        }

        .stat-card h5 {
            color: #64748B;
            font-size: 0.95rem;
            font-weight: 600;
            margin-bottom: 0.5rem;
        }

        .stat-card h2 {
            color: #1E293B;
            font-weight: 800;
            margin-bottom: 0;
        }
    /* خطوط ملونة أسفل الكروت للتمييز البصري */
    .card-doctors {
        border-bottom: 4px solid #10B981;
    }

    .card-patients {
        border-bottom: 4px solid #3B82F6;
    }

    .card-appointments {
        border-bottom: 4px solid #8B5CF6;
    }

    /* =================================================== */
    /* أزرار الإجراءات السريعة */
    /* =================================================== */
    .btn-quick {
        border-radius: 12px;
        padding: 0.7rem 1.5rem;
        font-weight: 600;
        border: none;
        transition: all 0.25s ease;
    }

    .btn-quick-patient {
        background-color: #EFF6FF;
        color: #2563EB;
    }

        .btn-quick-patient:hover {
            background-color: #2563EB;
            color: white;
        }

    .btn-quick-appointment {
        background-color: #ECFDF5;
        color: #059669;
    }

        .btn-quick-appointment:hover {
            background-color: #059669;
            color: white;
        }

    /* =================================================== */
    /* بار تحليل اليوم */
    /* =================================================== */
    .analysis-bar {
        background: #F8FAFC;
        border: 1px solid #E2E8F0;
        border-radius: 14px;
        padding: 1.2rem;
    }

    .analysis-title {
        font-weight: 700;
        color: #334155;
        font-size: 1rem;
    }

    .analysis-badge {
        padding: 0.4rem 0.8rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.9rem;
    }

    /* =================================================== */
    /* جداول مواعيد اليوم المخصصة لكل طبيب */
    /* =================================================== */
    .doctor-schedule-card {
        border: none;
        border-radius: 14px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03);
        overflow: hidden;
    }

    .doctor-header {
        background-color: #F1F5F9 !important;
        border-bottom: 1px solid #E2E8F0;
        padding: 1rem 1.5rem;
    }

    .doctor-title {
        color: #1E293B;
        font-weight: 700;
        font-size: 1.1rem;
    }

    .custom-table th {
        background-color: #F8FAFC;
        color: #64748B;
        font-weight: 600;
        font-size: 0.85rem;
        padding: 1rem !important;
        border-bottom: 1px solid #E2E8F0 !important;
    }

    .custom-table td {
        padding: 1rem !important;
        font-size: 0.95rem;
        border-bottom: 1px solid #F1F5F9;
    }

    .custom-table tbody tr:hover {
        background-color: #F8FAFC;
    }
</style>

<div class="container" dir="rtl">

    <div class="hero-section mb-4 d-flex align-items-center justify-content-between">
        <div>
            <h1><i class="bi bi-heart-pulse-fill me-2"></i> نظام إدارة العيادة</h1>
            <p>مرحباً بك مجدداً. يمكنك إدارة الأطباء والمرضى ومتابعة المواعيد اليومية بكل سهولة ومن مكان واحد.</p>
        </div>
        <i class="bi bi-shield-plus display-3 opacity-25 d-none d-md-block"></i>
    </div>

    <div class="row mb-4">
        <div class="col-md-4 mb-3">
            <div class="stat-card card-doctors text-center">
                <h5><i class="bi bi-person-heart text-success me-1"></i> إجمالي الأطباء</h5>
                <h2>@Model.DoctorsCount</h2>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="stat-card card-patients text-center">
                <h5><i class="bi bi-people text-primary me-1"></i> إجمالي المرضى</h5>
                <h2>@Model.PatientsCount</h2>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="stat-card card-appointments text-center">
                <h5><i class="bi bi-calendar-check text-purple me-1" style="color: #8B5CF6;"></i> كل المواعيد المسجلة</h5>
                <h2>@Model.AppointmentsCount</h2>
            </div>
        </div>
    </div>

    <div class="d-flex gap-3 mb-4 flex-wrap">
        <a asp-controller="Patients" asp-action="Create" class="btn btn-quick btn-quick-patient">
            <i class="bi bi-person-plus-fill me-1"></i> إضافة مريض جديد
        </a>
        <a asp-controller="Appointment" asp-action="Create" class="btn btn-quick btn-quick-appointment">
            <i class="bi bi-calendar-plus me-1"></i> حجز موعد جديد
        </a>
    </div>

    <div class="analysis-bar mb-4">
        <div class="row align-items-center">
            <div class="col-md-3 mb-2 mb-md-0">
                <span class="analysis-title"><i class="bi bi-bar-chart-line-fill me-2 text-secondary"></i> مؤشرات حركة اليوم:</span>
            </div>
            <div class="col-md-9 d-flex gap-2 flex-wrap">
                <span class="analysis-badge bg-white text-dark border">إجمالي مواعيد اليوم: <strong>@Model.TodayAppointmentsCount</strong></span>
                <span class="analysis-badge text-success" style="background-color: #DCFCE7;">مؤكد / منتهي: <strong>@Model.ConfirmedAppointmentsCount</strong></span>
                <span class="analysis-badge text-danger" style="background-color: #FEE2E2;">ملغي: <strong>@Model.CancelledAppointmentsCount</strong></span>
            </div>
        </div>
    </div>

    <h4 class="mb-3 text-dark font-weight-700"><i class="bi bi-calendar2-week me-2 text-primary"></i> بيان مواعيد اليوم وجدول الأطباء</h4>

    @if (Model.DoctorAppointments != null && Model.DoctorAppointments.Any())
    {
        @foreach (var doctor in Model.DoctorAppointments)
        {
            <div class="card doctor-schedule-card mb-4">
                <div class="card-header doctor-header d-flex align-items-center justify-content-between">
                    <span class="doctor-title">
                        <i class="bi bi-person-workspace text-primary me-2"></i> عيادة د. @doctor.Key
                    </span>
                    <span class="badge bg-primary rounded-pill">@doctor.Value.Count() مواعيد</span>
                </div>

                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table custom-table text-center align-middle mb-0">
                            <thead>
                                <tr>
                                    <th><i class="bi bi-person me-1"></i> اسم المريض</th>
                                    <th><i class="bi bi-clock me-1"></i> توقيت الحجز</th>
                                    <th>حالة الموعد</th>
                                    <th>إجراءات الإدارة السريعة</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in doctor.Value)
                                {
                                    <tr>
                                        <td class="font-weight-600">@item.Patient?.Patient_Name</td>

                                        <td>
                                            <span class="badge bg-light text-dark font-weight-500">
                                                @item.AppointmentDate.ToString("hh:mm tt")
                                            </span>
                                        </td>

                                        <td>
                                            @if (item.Status == "Pending")
                                            {
                                                <span class="badge rounded-pill bg-secondary px-3 py-2">انتظار الدفع</span>
                                            }
                                            else if (item.Status == "Paid")
                                            {
                                                <span class="badge rounded-pill bg-primary px-3 py-2">تم الدفع / مؤكد</span>
                                            }
                                            else if (item.Status == "Completed")
                                            {
                                                <span class="badge rounded-pill bg-success px-3 py-2">منتهي</span>
                                            }
                                            else if (item.Status == "Cancelled")
                                            {
                                                <span class="badge rounded-pill bg-danger px-3 py-2">ملغي</span>
                                            }
                                        </td>

                                        <td>
                                            @if (item.Status == "Pending")
                                            {
                                                <a asp-controller="Appointment" asp-action="Pay" asp-route-id="@item.Id"
                                                   class="btn btn-success btn-sm rounded-8 px-3 me-1">
                                                    <i class="bi bi-cash me-1"></i> دفع
                                                </a>

                                                <a asp-controller="Appointment" asp-action="Cancel" asp-route-id="@item.Id"
                                                   class="btn btn-warning btn-sm text-white rounded-8 px-3">
                                                    <i class="bi bi-x-circle me-1"></i> إلغاء
                                                </a>
                                            }
                                            else if (item.Status == "Paid")
                                            {
                                                <a asp-controller="Appointment" asp-action="Complete" asp-route-id="@item.Id"
                                                   class="btn btn-primary btn-sm rounded-8 px-3">
                                                    <i class="bi bi-check2-all me-1"></i> إنهاء وعمل كشف
                                                </a>
                                            }
                                            else if (item.Status == "Completed")
                                            {
                                                <span class="text-success small font-weight-600"><i class="bi bi-check-circle-fill me-1"></i> المريض دخل العيادة</span>
                                            }
                                            else if (item.Status == "Cancelled")
                                            {
                                                <span class="text-danger small font-weight-600"><i class="bi bi-slash-circle me-1"></i> تم إهمال الموعد</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="text-center py-5 bg-light rounded-16 border mt-2">
            <i class="bi bi-calendar-x display-5 text-muted d-block mb-3"></i>
            <p class="text-secondary mb-0">لا توجد أي مواعيد محجوزة لتاريخ اليوم.</p>
        </div>
    }
</div>
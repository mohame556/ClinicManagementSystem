@model Clinc.Models.Doctors

@{
    ViewData["Title"] = "تفاصيل الطبيب";
}

<div class="container mt-4" dir="rtl">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary m-0">
            <i class="bi bi-person-bounding-box me-2"></i> تفاصيل ملف الطبيب
        </h2>
        <span class="badge bg-info text-dark fs-6 p-2">ملف نشط</span>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-4">

            <div class="row align-items-center">
                <div class="col-md-2 text-center mb-3 mb-md-0">
                    <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 90px; height: 90px;">
                        <i class="bi bi-person-md text-primary fs-1"></i>
                    </div>
                </div>

                <div class="col-md-10">
                    <div class="row g-3 fs-5">
                        <div class="col-sm-4">
                            <span class="text-muted d-block small fw-bold mb-1">اسم الطبيب</span>
                            <span class="text-dark">@Model.Doctor_Name</span>
                        </div>

                        <div class="col-sm-4">
                            <span class="text-muted d-block small fw-bold mb-1">التخصص</span>
                            <span class="badge bg-primary-subtle text-primary border border-primary-subtle px-3 py-2 fs-6 mt-1">
                                @Model.Specialty
                            </span>
                        </div>

                        <div class="col-sm-4">
                            <span class="text-muted d-block small fw-bold mb-1">رقم الهاتف</span>
                            <span class="text-secondary direction-ltr d-inline-block">
                                @(string.IsNullOrEmpty(Model.Phone) ? "غير مسجل" : Model.Phone)
                            </span>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning px-4">
            <i class="bi bi-pencil-square"></i> تعديل البيانات
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary px-4">
            <i class="bi bi-arrow-right"></i> رجوع للقائمة
        </a>
    </div>
</div>
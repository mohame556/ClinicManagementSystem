@model Clinc.ViewModels.DoctorVM

@{
    ViewData["Title"] = "تعديل بيانات الطبيب";
}

<!-- أيقونات Bootstrap لتجميل التصميم -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    /* =================================================== */
    /* تنسيق كارد تعديل طبيب وعناصر الإدخال */
    /* =================================================== */
    .edit-doctor-card {
        background: #ffffff;
        border-radius: 16px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
        border: 1px solid #F1F5F9;
        padding: 2.5rem;
        max-width: 750px;
        margin: 2rem auto;
    }

    .form-label {
        font-weight: 600;
        color: #475569;
        margin-bottom: 0.6rem;
        font-size: 0.95rem;
    }

    .form-control {
        border-radius: 12px !important;
        padding: 0.75rem 1rem;
        border: 1.5px solid #E2E8F0;
        transition: all 0.25s ease;
        background-color: #F8FAFC;
    }

        .form-control:focus {
            border-color: #0D9488; /* لون Teal فخم لعمليات التعديل الطبية */
            box-shadow: 0 0 0 4px rgba(13, 148, 136, 0.12);
            background-color: #fff;
            outline: none;
        }

    .btn-submit {
        background: linear-gradient(135deg, #0D9488 0%, #0F766E 100%);
        border: none;
        border-radius: 12px;
        padding: 0.85rem 2rem;
        font-weight: 600;
        transition: all 0.25s ease;
    }

        .btn-submit:hover {
            transform: translateY(-1px);
            box-shadow: 0 5px 15px rgba(13, 148, 136, 0.3);
        }

    /* تنسيق صندوق ملخص الأخطاء */
    .validation-summary-errors {
        background-color: #FEE2E2;
        border: 1px solid #FCA5A5;
        border-radius: 12px;
        padding: 1rem 2rem;
        color: #B91C1C;
        margin-bottom: 1.5rem;
        font-size: 0.9rem;
    }

        .validation-summary-errors ul {
            margin-bottom: 0;
            padding-right: 1rem;
        }

    .text-danger {
        font-size: 0.85rem;
        font-weight: 500;
        margin-top: 0.25rem;
        display: block;
    }
</style>

<div class="container" dir="rtl">
    <div class="edit-doctor-card">

        <!-- عنوان الفورم التوضيحي -->
        <h3 class="text-center mb-4 font-weight-bold" style="color: #0D9488;">
            <i class="bi bi-pencil-square me-2"></i> تعديل بيانات الطبيب
        </h3>

        <form asp-action="Edit" method="post">

            <!-- ملخص أخطاء الـ Validation بعد نقله لأعلى وتنسيقه -->
            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="All" class="validation-summary-errors text-danger"></div>
            }

            <!-- الحقل المخفي للـ ID -->
            <input type="hidden" asp-for="Id" />

            <div class="row">
                <!-- اسم الطبيب -->
                <div class="col-md-6 mb-3">
                    <label class="form-label"><i class="bi bi-person-badge me-1" style="color: #0D9488;"></i> اسم الطبيب</label>
                    <input asp-for="Doctor_Name" class="form-control" />
                    <!-- تم إضافة الـ Validation span هنا للأمان -->
                    <span asp-validation-for="Doctor_Name" class="text-danger"></span>
                </div>

                <!-- التخصص -->
                <div class="col-md-6 mb-3">
                    <label class="form-label"><i class="bi bi-award me-1" style="color: #0D9488;"></i> التخصص</label>
                    <input asp-for="Specialty" class="form-control" />
                    <span asp-validation-for="Specialty" class="text-danger"></span>
                </div>
            </div>

            <!-- رقم الهاتف -->
            <div class="mb-3">
                <label class="form-label"><i class="bi bi-telephone me-1" style="color: #0D9488;"></i> رقم الهاتف</label>
                <input asp-for="Phone" class="form-control" />
                <span asp-validation-for="Phone" class="text-danger"></span>
            </div>

            <div class="row">
                <!-- رسوم الكشف -->
                <div class="col-md-6 mb-4">
                    <label class="form-label"><i class="bi bi-cash me-1" style="color: #0D9488;"></i> رسوم الكشف</label>
                    <div class="input-group">
                        <input asp-for="ExaminationFee" type="number" step="0.01" class="form-control" />
                    </div>
                    <span asp-validation-for="ExaminationFee" class="text-danger"></span>
                </div>

                <!-- رسوم إعادة الكشف -->
                <div class="col-md-6 mb-4">
                    <label class="form-label"><i class="bi bi-arrow-counterclockwise me-1" style="color: #0D9488;"></i> رسوم إعادة الكشف</label>
                    <div class="input-group">
                        <input asp-for="ReExaminationFee" type="number" step="0.01" class="form-control" />
                    </div>
                    <span asp-validation-for="ReExaminationFee" class="text-danger"></span>
                </div>
            </div>

            <!-- زر حفظ التعديلات -->
            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary btn-submit text-white">
                    <i class="bi bi-cloud-arrow-up-fill me-2"></i> حفظ التعديلات الحالية
                </button>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
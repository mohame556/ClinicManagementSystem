@model Clinc.ViewModels.DoctorVM

@{
    ViewData["Title"] = "إضافة طبيب";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    /* =================================================== */
    /* تنسيق كارد إضافة طبيب وعناصر الإدخال */
    /* =================================================== */
    .doctor-card {
        background: #ffffff;
        border-radius: 16px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
        border: 1px solid #F1F5F9;
        padding: 2.5rem;
        max-width: 750px;
        margin: 2rem auto;
    }

    .form-label {
        font-weight: 600;
        color: #475569;
        margin-bottom: 0.6rem;
        font-size: 0.95rem;
    }

    .form-control {
        border-radius: 12px !important;
        padding: 0.75rem 1rem;
        border: 1.5px solid #E2E8F0;
        transition: all 0.25s ease;
        background-color: #F8FAFC;
    }

        .form-control:focus {
            border-color: #10B981; /* لون أخضر مريح للعين لعمليات الإضافة الناجحة */
            box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.12);
            background-color: #fff;
            outline: none;
        }

    .btn-submit {
        background: linear-gradient(135deg, #10B981 0%, #059669 100%);
        border: none;
        border-radius: 12px;
        padding: 0.85rem 2rem;
        font-weight: 600;
        transition: all 0.25s ease;
    }

        .btn-submit:hover {
            transform: translateY(-1px);
            box-shadow: 0 5px 15px rgba(5, 150, 105, 0.3);
        }
    /* تنسيق رسائل الخطأ لتكون أنيقة */
    .text-danger {
        font-size: 0.85rem;
        font-weight: 500;
        margin-top: 0.25rem;
        display: block;
    }
</style>

<div class="container" dir="rtl">
    <div class="doctor-card">
        <h3 class="text-center mb-4 text-success font-weight-bold">
            <i class="bi bi-person-plus-fill me-2"></i> إضافة طبيب جديد
        </h3>

        <form asp-action="Create" method="post">

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label"><i class="bi bi-person text-success me-1"></i> اسم الطبيب *</label>
                    <input asp-for="Doctor_Name" class="form-control" placeholder="ادخل الاسم بالكامل" />
                    <span asp-validation-for="Doctor_Name" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label"><i class="bi bi-textarea-resize text-success me-1"></i> التخصص *</label>
                    <input asp-for="Specialty" class="form-control" placeholder="مثال: باطنة، أطفال..." />
                    <span asp-validation-for="Specialty" class="text-danger"></span>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label"><i class="bi bi-telephone text-success me-1"></i> رقم الهاتف *</label>
                <input asp-for="Phone" class="form-control" placeholder="01xxxxxxxxx" />
                <span asp-validation-for="Phone" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-6 mb-4">
                    <label class="form-label"><i class="bi bi-cash text-success me-1"></i> رسوم الكشف *</label>
                    <div class="input-group">
                        <input asp-for="ExaminationFee" type="number" step="0.01" class="form-control" placeholder="0.00" />
                    </div>
                    <span asp-validation-for="ExaminationFee" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-4">
                    <label class="form-label"><i class="bi bi-arrow-counterclockwise text-success me-1"></i> رسوم إعادة الكشف *</label>
                    <div class="input-group">
                        <input asp-for="ReExaminationFee" type="number" step="0.01" class="form-control" placeholder="0.00" />
                    </div>
                    <span asp-validation-for="ReExaminationFee" class="text-danger"></span>
                </div>
            </div>

            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-success btn-submit text-white">
                    <i class="bi bi-check-circle-fill me-2"></i> حفظ بيانات الطبيب
                </button>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
@model IEnumerable<Clinc.Models.Doctors>

@{
    ViewData["Title"] = "الأطباء";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<style>
    /* تأثيرات جمالية مخصصة للواجهة */
    body {
        background-color: #f8f9fa; /* خلفية هادئة للموقع */
    }
    .doctor-card {
        border-radius: 16px !important;
        transition: all 0.3s ease-in-out;
        background: #ffffff;
    }
    .doctor-card:hover {
        transform: translateY(-8px); /* حركة خفيفة للأعلى عند مرور الماوس */
        box-shadow: 0 1rem 3rem rgba(0, 0, 0, 0.08) !important; /* ظل ناعم */
    }
    .icon-box {
        width: 70px;
        height: 70px;
        background: rgba(13, 110, 253, 0.1);
        color: #0d6efd;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 15px;
        font-size: 28px;
    }
    .fee-badge {
        background-color: #f1f3f5;
        border-radius: 8px;
        padding: 6px 12px;
        font-size: 0.9rem;
    }
</style>

<div class="container my-5" dir="rtl">

    <div class="d-flex justify-content-between align-items-center mb-5 pb-3 border-bottom">
        <h2 class="fw-bold text-dark m-0">
            <i class="bi bi-people-fill text-primary me-2"></i> قائمة الأطباء
        </h2>
        <a asp-action="Create" class="btn btn-primary px-4 py-2 shadow-sm rounded-pill">
            <i class="bi bi-plus-lg"></i> إضافة طبيب جديد
        </a>
    </div>

    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-xl-4 col-md-6">
                <div class="card doctor-card border-0 shadow-sm h-100">
                    <div class="card-body p-4 text-center d-flex flex-column justify-content-between">

                        <div>
                            <div class="icon-box">
                                <i class="bi bi-person-vcard"></i>
                            </div>

                            <h5 class="fw-bold text-dark mb-1">@item.Doctor_Name</h5>

                            <span class="badge bg-light text-primary rounded-pill px-3 py-2 mb-3 fw-semibold">
                                @item.Specialty
                            </span>

                            <p class="text-muted small mb-4">
                                <i class="bi bi-telephone text-success me-1"></i> @item.Phone
                            </p>

                            <div class="d-flex justify-content-center gap-2 mb-4">
                                <div class="fee-badge flex-fill text-secondary">
                                    <span class="d-block small text-muted">كشف</span>
                                    <strong class="text-dark">@item.ExaminationFee</strong> ج.م
                                </div>
                                <div class="fee-badge flex-fill text-secondary">
                                    <span class="d-block small text-muted">إعادة</span>
                                    <strong class="text-dark">@item.ReExaminationFee</strong> ج.م
                                </div>
                            </div>
                        </div>

                        <div class="d-flex gap-2 mt-auto">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info w-100 rounded-8 btn-sm py-2">
                                <i class="bi bi-eye"></i> تفاصيل
                            </a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary w-100 rounded-8 btn-sm py-2">
                                <i class="bi bi-pencil-square"></i> تعديل
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger w-100 rounded-8 btn-sm py-2">
                                <i class="bi bi-trash"></i> حذف
                            </a>
                        </div>

                    </div>
                </div>
            </div>
        }
    </div>
</div>
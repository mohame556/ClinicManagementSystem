@{
    ViewData["Title"] = "إدارة المستخدمين";

    // جلب البيانات وتأمينها من الـ Null برمجياً في الأعلى لمنع أخطاء الـ Context
    var usersWithRoles = ViewBag.UsersWithRoles as List<(Clinc.Models.AppUser User, string Role)> ?? new List<(Clinc.Models.AppUser User, string Role)>();

    var admins = usersWithRoles.Where(x => x.Role == "Admin").ToList();
    var regularUsers = usersWithRoles.Where(x => x.Role == "User").ToList();
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
   
    .custom-card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
        background: #ffffff;
        overflow: hidden;
        margin-top: 2rem;
    }

    .custom-card-header {
        background: #ffffff;
        border-bottom: 1px solid #F1F5F9;
        padding: 1.5rem 2rem;
    }

    .main-title {
        font-weight: 700;
        color: #1E293B;
        font-size: 1.4rem;
    }

    .btn-create {
        background: linear-gradient(135deg, #3B82F6 0%, #2563EB 100%);
        border: none;
        border-radius: 10px;
        padding: 0.6rem 1.3rem;
        font-weight: 600;
        transition: all 0.25s ease;
    }

        .btn-create:hover {
            box-shadow: 0 4px 12px rgba(37, 99, 235, 0.25);
            transform: translateY(-1px);
        }

    .custom-table {
        margin-bottom: 0;
    }

        .custom-table thead {
            background-color: #F8FAFC;
        }

        .custom-table th {
            color: #64748B;
            font-weight: 600;
            font-size: 0.9rem;
            border-bottom: 2px solid #E2E8F0 !important;
            padding: 1.2rem 1rem !important;
        }

        .custom-table td {
            padding: 1.1rem 1rem !important;
            color: #334155;
            font-size: 0.95rem;
            border-bottom: 1px solid #F1F5F9;
        }

        .custom-table tbody tr {
            transition: background-color 0.2s ease;
        }

            .custom-table tbody tr:hover {
                background-color: #F8FAFC !important;
            }

    /* تمييز لطيف للأدوار وحقول النصوص */
    .role-badge-admin {
        background-color: #FEE2E2;
        color: #DC2626;
        padding: 0.3rem 0.6rem;
        border-radius: 6px;
        font-weight: 600;
        font-size: 0.85rem;
    }

    .role-badge-user {
        background-color: #DBEAFE;
        color: #2563EB;
        padding: 0.3rem 0.6rem;
        border-radius: 6px;
        font-weight: 600;
        font-size: 0.85rem;
    }

    .email-text {
        color: #475569;
        font-weight: 500;
    }
</style>

<div class="container" dir="rtl">
    <div class="card custom-card">

        <div class="card-header custom-card-header d-flex justify-content-between align-items-center">
            <h3 class="mb-0 main-title">
                <i class="bi bi-shield-lock-fill text-primary me-2"></i> إدارة حسابات وصلاحيات المستخدمين
            </h3>

            <a asp-action="Create" class="btn btn-primary btn-create text-white">
                <i class="bi bi-person-plus-fill me-1"></i> إضافة مستخدم جديد
            </a>
        </div>

        <div class="card-body p-0">

            <div class="p-3 bg-light border-bottom">
                <h4 class="h6 mb-0 text-danger fw-bold">
                    <i class="bi bi-person-badge-fill me-1"></i> مديرين النظام (Admins)
                </h4>
            </div>
            <div class="table-responsive">
                <table class="table custom-table text-center align-middle">
                    <thead>
                        <tr>
                            <th><i class="bi bi-person me-1"></i> الاسم</th>
                            <th><i class="bi bi-envelope me-1"></i> الإيميل</th>
                            <th><i class="bi bi-geo-alt me-1"></i> العنوان</th>
                            <th><i class="bi bi-sliders me-1"></i> الدور</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (admins.Any())
                        {
                            @foreach (var item in admins)
                            {
                                <tr>
                                    <td class="font-weight-600 text-start ps-4">@(item.User?.FullName ?? "بدون اسم")</td>
                                    <td class="email-text">@(item.User?.Email ?? "-")</td>
                                    <td class="text-secondary">@(string.IsNullOrEmpty(item.User?.Address) ? "غير محدد" : item.User.Address)</td>
                                    <td>
                                        <span class="role-badge-admin">مدير نظام</span>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center py-4 text-muted">لا يوجد مدراء نظام مسجلين حالياً.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="py-2 bg-light border-top border-bottom"></div>

            <div class="p-3 bg-light border-bottom">
                <h4 class="h6 mb-0 text-primary fw-bold">
                    <i class="bi bi-people-fill me-1"></i> المستخدمين والموظفين (Users)
                </h4>
            </div>
            <div class="table-responsive">
                <table class="table custom-table text-center align-middle">
                    <thead>
                        <tr>
                            <th><i class="bi bi-person me-1"></i> الاسم</th>
                            <th><i class="bi bi-envelope me-1"></i> الإيميل</th>
                            <th><i class="bi bi-geo-alt me-1"></i> العنوان</th>
                            <th><i class="bi bi-sliders me-1"></i> الدور</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (regularUsers.Any())
                        {
                            @foreach (var item in regularUsers)
                            {
                                <tr>
                                    <td class="text-start ps-4">@(item.User?.FullName ?? "بدون اسم")</td>
                                    <td class="email-text">@(item.User?.Email ?? "-")</td>
                                    <td class="text-secondary">@(string.IsNullOrEmpty(item.User?.Address) ? "غير محدد" : item.User.Address)</td>
                                    <td>
                                        <span class="role-badge-user">مستخدم</span>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center py-4 text-muted">لا يوجد مستخدمين عاديين مسجلين حالياً.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

        </div>
    </div>
</div>
<div class="card custom-card mt-4">
    <div class="card-header custom-card-header">
        <h4 class="mb-0">
            <i class="bi bi-gear-fill text-primary me-2"></i>
            إعدادات النظام
        </h4>
    </div>

    <div class="card-body">

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">
                @TempData["Success"]
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">
                @TempData["Error"]
            </div>
        }

        <form asp-controller="System"
              asp-action="Backup"
              method="post">

            @Html.AntiForgeryToken()

            <button type="submit" class="btn btn-success">

                <i class="bi bi-database-fill-down"></i>

                أخذ نسخة احتياطية

            </button>
            @if (User.IsInRole("SuperAdmin"))
            {
                <a asp-controller="License"
                   asp-action="Index"
                   class="btn btn-warning">

                    <i class="bi bi-key-fill"></i>

                    تفعيل البرنامج

                </a>
            }

        </form>

    </div>
</div>

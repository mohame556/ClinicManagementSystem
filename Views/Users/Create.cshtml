@model Clinc.ViewModels.UserVM

@{
    ViewData["Title"] = "إضافة مستخدم جديد";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
   
    .custom-card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
        background: #ffffff;
        overflow: hidden;
        margin-top: 2rem;
    }

    .custom-card-header {
        background: #ffffff;
        border-bottom: 1px solid #F1F5F9;
        padding: 1.5rem 2rem;
    }

    .main-title {
        font-weight: 700;
        color: #1E293B;
        font-size: 1.4rem;
    }

    /* زر الحفظ بالتدرج الأزرق المعتمد في صفحة سجل المرضى */
    .btn-submit-gradient {
        background: linear-gradient(135deg, #3B82F6 0%, #2563EB 100%);
        border: none;
        border-radius: 10px;
        padding: 0.6rem 2rem;
        font-weight: 600;
        transition: all 0.25s ease;
    }

        .btn-submit-gradient:hover {
            box-shadow: 0 4px 12px rgba(37, 99, 235, 0.25);
            transform: translateY(-1px);
        }

    /* ستايل مخصص للحقول لتبدو متناسقة مع حواف الجدول الكبيرة */
    .custom-form-control {
        border: 1px solid #E2E8F0;
        border-radius: 10px;
        padding: 0.75rem 1rem;
        font-size: 0.95rem;
        color: #334155;
        transition: all 0.2s ease;
    }

        .custom-form-control:focus {
            border-color: #3B82F6;
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
            background-color: #ffffff;
        }

    .custom-form-label {
        font-weight: 600;
        color: #64748B;
        font-size: 0.9rem;
        margin-bottom: 0.5rem;
    }
</style>

<div class="container" dir="rtl">
    <div class="card custom-card">

        <div class="card-header custom-card-header">
            <h3 class="mb-0 main-title">
                <i class="bi bi-person-plus-fill text-primary me-2"></i> إضافة مستخدم جديد للنظام
            </h3>
        </div>

        <div class="card-body p-4 p-md-5">
            <form asp-action="Create" method="post" class="needs-validation">

                <div asp-validation-summary="All" class="text-danger mb-4 small fw-bold"></div>

                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label asp-for="FullName" class="form-label custom-form-label">
                            <i class="bi bi-person me-1"></i> الاسم الكامل
                        </label>
                        <input asp-for="FullName" placeholder="أدخل الاسم الكامل" class="form-control custom-form-control" />
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-4">
                        <label asp-for="Email" class="form-label custom-form-label">
                            <i class="bi bi-envelope me-1"></i> البريد الإلكتروني
                        </label>
                        <input asp-for="Email" type="email" placeholder="example@domain.com" class="form-control custom-form-control" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-4">
                        <label asp-for="Address" class="form-label custom-form-label">
                            <i class="bi bi-geo-alt me-1"></i> العنوان
                        </label>
                        <input asp-for="Address" placeholder="العنوان بالتفصيل" class="form-control custom-form-control" />
                        <span asp-validation-for="Address" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-4">
                        <label asp-for="Role" class="form-label custom-form-label">
                            <i class="bi bi-sliders me-1"></i> دور المستخدم (Role)
                        </label>
                        <select asp-for="Role" class="form-select custom-form-control">
                            <option value="">-- اختر الدور --</option>
                            @if (Model?.RolesList != null)
                            {
                                @foreach (var role in Model.RolesList)
                                {
                                    <option value="@role">@role</option>
                                }
                            }
                        </select>
                        <span asp-validation-for="Role" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-4">
                        <label asp-for="Password" class="form-label custom-form-label">
                            <i class="bi bi-lock me-1"></i> كلمة المرور
                        </label>
                        <input asp-for="Password" type="password" placeholder="أدخل كلمة المرور" class="form-control custom-form-control" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-4">
                        <label asp-for="ConfirmPassword" class="form-label custom-form-label">
                            <i class="bi bi-shield-check me-1"></i> تأكيد كلمة المرور
                        </label>
                        <input asp-for="ConfirmPassword" type="password" placeholder="أعد كتابة كلمة المرور" class="form-control custom-form-control" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>
                </div>

                <div class="d-flex justify-content-start gap-2 mt-3 pt-3 border-top">
                    <button type="submit" class="btn btn-primary btn-submit-gradient text-white">
                        <i class="bi bi-check-circle-fill me-1"></i> حفظ البيانات
                    </button>
                    <a asp-action="Index" class="btn btn-light px-4 py-2 text-secondary fw-semibold" style="border-radius: 10px;">
                        إلغاء
                    </a>
                </div>

            </form>
        </div>

    </div>
</div>
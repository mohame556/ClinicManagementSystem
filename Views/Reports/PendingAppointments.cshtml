@model List<Clinc.Models.Appointment>

@{
    ViewData["Title"] = "الحجوزات المعلقة";
}

<div class="container mt-4" dir="rtl">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-warning dark-text m-0">
            <i class="bi bi-clock-history me-2"></i> الحجوزات قيد الانتظار
        </h2>
        @if (Model != null && Model.Any())
        {
            <span class="badge bg-warning text-dark fs-6 px-3 py-2">
                يوجد (@Model.Count) طلب معلق
            </span>
        }
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="table-responsive card shadow-sm border-0">
            <table class="table table-hover align-middle mb-0 text-center">
                <thead class="table-warning text-dark">
                    <tr>
                        <th scope="col" class="text-start pr-4">اسم المريض</th>
                        <th scope="col">الطبيب المعالج</th>
                        <th scope="col">التاريخ والوقت</th>
                        <th scope="col">الحالة</th>
                        <th scope="col" class="d-print-none">إجراءات سريعة</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-start fw-bold pr-4">
                                @(item.Patient?.Patient_Name ?? "مريض غير مسجل")
                            </td>

                            <td>
                                <span class="text-muted small">د./</span> @(item.Doctor?.Doctor_Name ?? "غير محدد")
                            </td>

                            <td>
                                <span class="direction-ltr d-inline-block text-secondary">
                                    @item.AppointmentDate.ToString("dd/MM/yyyy hh:mm tt")
                                </span>
                            </td>

                            <td>
                                <span class="badge bg-warning-subtle text-warning-dark border border-warning px-3 py-2">
                                    @item.Status
                                </span>
                            </td>

                            <td class="d-print-none">
                                <div class="d-flex justify-content-center gap-1">
                                    <a asp-action="Approve" asp-route-id="@item.Id" class="btn btn-sm btn-success px-2" title="تأكيد الموعد">
                                        <i class="bi bi-check-lg"></i> قبول
                                    </a>
                                    <a asp-action="Cancel" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger px-2" title="إلغاء الموعد">
                                        <i class="bi bi-x-lg"></i> إلغاء
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-light border px-2" title="التفاصيل">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm text-center p-5 bg-white rounded-3">
            <div class="card-body">
                <div class="bg-success-subtle text-success rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                    <i class="bi bi-check-circle-fill fs-1"></i>
                </div>
                <h4 class="text-dark mb-2">عمل ممتاز! لا توجد حجوزات معلقة</h4>
                <p class="text-muted mb-0">تمت معالجة وتأكيد كافة مواعيد العيادة بنجاح حتى هذه اللحظة.</p>
            </div>
        </div>
    }
</div>
@model IEnumerable<Clinc.Models.Appointment>

@{
    ViewData["Title"] = "المواعيد";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    /* =================================================== */
    /* تنسيق كارد الجدول ليكون عصري ونظيف */
    /* =================================================== */
    .custom-card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
        background: #ffffff;
        overflow: hidden;
        margin-top: 2rem;
    }

    .custom-card-header {
        background: #ffffff;
        border-bottom: 1px solid #F1F5F9;
        padding: 1.5rem 2rem;
    }

    .main-title {
        font-weight: 700;
        color: #1E293B;
        font-size: 1.4rem;
    }

    .btn-create {
        background: linear-gradient(135deg, #3B82F6 0%, #2563EB 100%);
        border: none;
        border-radius: 10px;
        padding: 0.6rem 1.3rem;
        font-weight: 600;
        transition: all 0.25s ease;
    }

        .btn-create:hover {
            box-shadow: 0 4px 12px rgba(37, 99, 235, 0.25);
            transform: translateY(-1px);
        }

    /* =================================================== */
    /* تنسيقات الجدول المودرن */
    /* =================================================== */
    .custom-table {
        margin-bottom: 0;
    }

        .custom-table thead {
            background-color: #F8FAFC;
        }

        .custom-table th {
            color: #64748B;
            font-weight: 600;
            font-size: 0.9rem;
            text-transform: uppercase;
            border-bottom: 2px solid #E2E8F0 !important;
            padding: 1.2rem 1rem !important;
        }

        .custom-table td {
            padding: 1.1rem 1rem !important;
            color: #334155;
            font-size: 0.95rem;
            border-bottom: 1px solid #F1F5F9;
        }

        .custom-table tbody tr {
            transition: background-color 0.2s ease;
        }
            /* تأثير أنيق عند تمرير الماوس فوق الصف */
            .custom-table tbody tr:hover {
                background-color: #F8FAFC !important;
            }

    /* بادجات مخصصة لعرض الحالة ومتابعة */
    .status-badge {
        padding: 0.4rem 0.8rem;
        border-radius: 8px;
        font-size: 0.85rem;
        font-weight: 600;
        display: inline-block;
    }

    .badge-success {
        background-color: #DCFCE7;
        color: #15803D;
    }

    .badge-warning {
        background-color: #FEF9C3;
        color: #A16207;
    }

    .badge-danger {
        background-color: #FEE2E2;
        color: #B91C1C;
    }

    .badge-info {
        background-color: #E0F2FE;
        color: #0369A1;
    }

    /* تنسيق أزرار التحكم الصغيرة */
    .action-btn {
        border-radius: 8px;
        width: 35px;
        height: 35px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin: 0 2px;
        transition: all 0.2s ease;
        border: none;
    }

        .action-btn:hover {
            transform: translateY(-1px);
        }
</style>

<div class="container" dir="rtl">
    <div class="card custom-card">

        <div class="card-header custom-card-header d-flex justify-content-between align-items-center">
            <h3 class="mb-0 main-title">
                <i class="bi bi-calendar3 text-primary me-2"></i> إدارة مواعيد العيادة
            </h3>

            <a asp-action="Create" class="btn btn-primary btn-create text-white">
                <i class="bi bi-plus-lg me-1"></i> حجز موعد جديد
            </a>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table custom-table text-center align-middle">
                    <thead>
                        <tr>
                            <th>رقم الموعد</th>
                            <th><i class="bi bi-person me-1"></i> المريض</th>
                            <th><i class="bi bi-person-badge me-1"></i> الطبيب</th>
                            <th><i class="bi bi-clock me-1"></i> موعد الحجز</th>
                            <th>الحالة</th>
                            <th>استشارة/متابعة</th>
                            <th>الإجراءات</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="text-secondary font-weight-bold">#@item.Id</td>

                                    <td class="font-weight-600">@item.Patient?.Patient_Name</td>

                                    <td><span class="text-primary">د.</span> @item.Doctor?.Doctor_Name</td>

                                    <td>
                                        <span class="d-block font-weight-500">@item.AppointmentDate.ToString("dd/MM/yyyy")</span>
                                        <small class="text-muted">@item.AppointmentDate.ToString("hh:mm tt")</small>
                                    </td>

                                    <td>
                                        @{
                                            var statusClass = item.Status == "مؤكد" || item.Status == "منتهي" ? "badge-success" :
                                            item.Status == "انتظار" ? "badge-warning" : "badge-danger";
                                        }
                                        <span class="status-badge @statusClass">
                                            @item.Status
                                        </span>
                                    </td>

                                    <td>
                                        @if (item.IsFollowUp)
                                        {
                                            <span class="status-badge badge-info"><i class="bi bi-arrow-repeat me-1"></i> متابعة</span>
                                        }
                                        else
                                        {
                                            <span class="status-badge badge-success"><i class="bi bi-calendar-check me-1"></i> كشف جديد</span>
                                        }
                                    </td>

                                    <td>
                                        <a asp-action="Details" asp-route-id="@item.Id"
                                           class="btn btn-info text-white action-btn" title="عرض التفاصيل">
                                            <i class="bi bi-eye-fill"></i>
                                        </a>

                                        @* <a asp-action="Edit" asp-route-id="@item.Id"
                                           class="btn btn-warning text-white action-btn" title="تعديل الموعد">
                                            <i class="bi bi-pencil-square"></i>
                                        </a> *@
                                        @if (User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
                                        {
                                            <a asp-action="Delete" asp-route-id="@item.Id"
                                            class="btn btn-danger text-white action-btn" title="إلغاء / حذف">
                                                <i class="bi bi-trash3-fill"></i>
                                            </a>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5 text-muted">
                                    <i class="bi bi-folder-x display-6 d-block mb-3 text-secondary"></i>
                                    لا توجد مواعيد مسجلة في المنظومة حالياً.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</div>
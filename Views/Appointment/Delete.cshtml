
@model Clinc.Models.Appointment

@{
    ViewData["Title"] = "حذف الموعد";
}

<div class="container mt-4" dir="rtl">
    <h2 class="text-danger mb-4">حذف الموعد</h2>

    <div class="alert alert-warning d-flex align-items-center" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        <div>
            هل أنت متأكد أنك تريد حذف هذا الموعد؟ لا يمكن التراجع عن هذا الإجراء.
        </div>
    </div>

    <div class="card shadow-sm p-4 mb-4">
        <h4 class="card-title text-muted mb-3">تفاصيل الموعد</h4>
        <hr />
        <dl class="row fs-5">
            <dt class="col-sm-3 text-secondary">المريض:</dt>
            <dd class="col-sm-9 fw-bold">@(Model.Patient?.Patient_Name ?? "غير محدد")</dd>

            <dt class="col-sm-3 text-secondary">الدكتور:</dt>
            <dd class="col-sm-9 fw-bold">@(Model.Doctor?.Doctor_Name ?? "غير محدد")</dd>

            <dt class="col-sm-3 text-secondary">التاريخ والوقت:</dt>
            <dd class="col-sm-9 text-dark">@Model.AppointmentDate.ToString("dd/MM/yyyy hh:mm tt")</dd>
        </dl>
    </div>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        
        <button type="submit" class="btn btn-danger px-4 me-2">تأكيد الحذف</button>
        <a asp-action="Index" class="btn btn-outline-secondary px-4">إلغاء</a>
    </form>
</div>
@model Clinc.Models.Patients

@{
    ViewData["Title"] = "حذف المريض";
}

<div class="container mt-4" dir="rtl">
    <h2 class="text-danger mb-4"><i class="bi bi-person-dash-fill me-2"></i> حذف ملف مريض</h2>

    <div class="alert alert-danger d-flex align-items-center p-3 mb-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill fs-4 me-3"></i>
        <div>
            <strong>تحذير:</strong> هل أنت متأكد تماماً من حذف المريض: <strong class="underline">@Model.Patient_Name</strong>؟
            <br />
            <small class="text-dark-50">حذف ملف المريض سيؤدي إلى إزالة بياناته السجلية وقد يؤثر على تاريخ مواعيده.</small>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-light py-3">
            <h5 class="card-title m-0 text-muted">مراجعة بيانات الملف المحدّد</h5>
        </div>
        <div class="card-body p-4">
            <div class="row g-3 fs-5">
                <div class="col-md-6">
                    <span class="text-muted d-block small mb-1">اسم المريض الثنائي/الثلاثي</span>
                    <strong class="text-dark">@Model.Patient_Name</strong>
                </div>

                <div class="col-md-6">
                    <span class="text-muted d-block small mb-1">رقم الهاتف للتواصل</span>
                    <span class="text-secondary direction-ltr d-inline-block">
                        @(string.IsNullOrEmpty(Model.Phone) ? "غير مسجل" : Model.Phone)
                    </span>
                </div>
            </div>
        </div>
    </div>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-danger px-4">تأكيد الحذف النهائي</button>
            <a asp-action="Index" class="btn btn-outline-secondary px-4">إلغاء والتراجع</a>
        </div>
    </form>
</div>